{
  "info": {
    "name": "PZ9 — Redis Cache Demo",
    "description": "Демонстрация cache-aside: hit, miss, инвалидация, fallback",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "auth_url", "value": "http://localhost:8081" },
    { "key": "tasks_url", "value": "http://localhost:8082" },
    { "key": "token", "value": "" },
    { "key": "task_id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Login (получить токен)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{auth_url}}/v1/auth/login",
          "host": ["{{auth_url}}"],
          "path": ["v1", "auth", "login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"student\",\n  \"password\": \"student\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.access_token) {",
              "  pm.collectionVariables.set('token', json.access_token);",
              "  pm.test('Token received', function() { pm.expect(json.access_token).to.be.a('string'); });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Create Task (создать задачу)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{tasks_url}}/v1/tasks",
          "host": ["{{tasks_url}}"],
          "path": ["v1", "tasks"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Cache test task\",\n  \"description\": \"Задача для проверки Redis кэша\",\n  \"due_date\": \"2026-12-31\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.id) {",
              "  pm.collectionVariables.set('task_id', json.id);",
              "  pm.test('Task created, ID saved', function() { pm.expect(json.id).to.be.a('string'); });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "3. GET Task — cache MISS",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{tasks_url}}/v1/tasks/{{task_id}}",
          "host": ["{{tasks_url}}"],
          "path": ["v1", "tasks", "{{task_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "pm.test('Response has title', function() {",
              "  pm.expect(pm.response.json().title).to.eql('Cache test task');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4. GET Task — cache HIT",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{tasks_url}}/v1/tasks/{{task_id}}",
          "host": ["{{tasks_url}}"],
          "path": ["v1", "tasks", "{{task_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "pm.test('Same task returned', function() {",
              "  pm.expect(pm.response.json().title).to.eql('Cache test task');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "5. PATCH Task — инвалидация кэша",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{tasks_url}}/v1/tasks/{{task_id}}",
          "host": ["{{tasks_url}}"],
          "path": ["v1", "tasks", "{{task_id}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Updated cache task\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "pm.test('Title updated', function() {",
              "  pm.expect(pm.response.json().title).to.eql('Updated cache task');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "6. GET Task — cache MISS после PATCH",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{tasks_url}}/v1/tasks/{{task_id}}",
          "host": ["{{tasks_url}}"],
          "path": ["v1", "tasks", "{{task_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "pm.test('Updated title from DB', function() {",
              "  pm.expect(pm.response.json().title).to.eql('Updated cache task');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "7. DELETE Task — инвалидация кэша",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{tasks_url}}/v1/tasks/{{task_id}}",
          "host": ["{{tasks_url}}"],
          "path": ["v1", "tasks", "{{task_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 204', function() { pm.response.to.have.status(204); });"
            ]
          }
        }
      ]
    },
    {
      "name": "8. GET Task — 404 после DELETE",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{tasks_url}}/v1/tasks/{{task_id}}",
          "host": ["{{tasks_url}}"],
          "path": ["v1", "tasks", "{{task_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404', function() { pm.response.to.have.status(404); });"
            ]
          }
        }
      ]
    },
    {
      "name": "9. Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{tasks_url}}/health",
          "host": ["{{tasks_url}}"],
          "path": ["health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "pm.test('Service OK', function() {",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
